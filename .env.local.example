# OpenAI — embeddings (text-embedding-3-small) + LLM (gpt-4o)
OPENAI_API_KEY=sk-...

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=atpl_chunks

# Cohere — reranking (optional but strongly recommended)
# Free tier: https://cohere.com → API Keys
COHERE_API_KEY=your-cohere-api-key

# Feature flags
ENABLE_RERANK=true
